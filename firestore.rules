rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------
    // readings collection
    // ---------------------------------------------------------------
    // Written by the Raspberry Pi 5 using the Firebase Admin SDK
    // with a service account. The Admin SDK bypasses these rules,
    // so we can safely deny all client writes here.
    //
    // READ access is public (allow read: if true).
    //
    // TRADEOFF / SECURITY NOTE:
    //   Allowing public reads means anyone who discovers your Firebase
    //   config (e.g., from browser DevTools) can read all telemetry
    //   data. For a pet-health device this is typically acceptable,
    //   but consider the following mitigations if needed:
    //
    //   Option A — Require Firebase Auth (anonymous or email/password):
    //     allow read: if request.auth != null;
    //   Then call signInAnonymously() (or equivalent) in firebase.ts
    //   before the first Firestore query. This prevents casual
    //   scraping without requiring user account creation.
    //
    //   Option B — Restrict by auth UID (family members only):
    //     allow read: if request.auth != null
    //                 && request.auth.uid in ['uid1', 'uid2'];
    //   Requires users to sign in with Firebase Auth.
    //
    // The current "allow read: if true" rule is the simplest starting
    // point. Upgrade to Option A/B when ready for production.
    // ---------------------------------------------------------------

    match /readings/{docId} {
      allow read:  if true;   // See tradeoff note above
      allow write: if false;  // Writes only via Admin SDK (Pi device)
    }

    // Deny access to all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
